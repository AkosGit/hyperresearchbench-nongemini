# Secrets — NEVER commit. API keys live in a local .env, auto-loaded by
# compare.sh / grade.sh. Keep keys out of the repo and off GitHub.
.env
*.env
DeepResearch-Bench/.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Per-query run artifacts (huge — vault contents, raw PDFs)
DeepResearch-Bench/runs/
DeepResearch-Bench/runs_*/

# Upstream DRB clone (re-cloned by setup.sh)
DeepResearch-Bench/deep_research_bench/

# Original-hyperresearch checkout (re-cloned by compare.sh; has its own .git)
DeepResearch-Bench/.original_checkout/

# Eval outputs
DeepResearch-Bench/results/*.jsonl
DeepResearch-Bench/results/*_score.json
DeepResearch-Bench/results/raw_*/
DeepResearch-Bench/results/cleaned_*/

# Local notes
.idea/
.vscode/
*.log
*.tmp

# OS
.DS_Store
Thumbs.db
